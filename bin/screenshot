#!/bin/zsh

emulate -L zsh
setopt pipefail

mode=${1:-menu}

usage() {
    print -u2 "usage: screenshot [menu|desktop|monitor|window|region]"
}

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "Screenshot" "$1"
    fi
}

die() {
    print -u2 "screenshot: $*"
    notify "$*"
    exit 1
}

need() {
    command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

settle_screen() {
    sleep 0.15
}

open_editor() {
    need swappy
    swappy -f -
}

open_editor_file() {
    need swappy
    swappy -f "$1"
}

choose_mode() {
    need rofi

    local choice
    choice=$(
        printf '%s\n' \
            '📐 Region' \
            '🪟 Window' \
            '🖥️ Monitor' \
            '🌐 Desktop' |
            rofi -dmenu -p '📸 Screenshot'
    ) || return 1

    case $choice in
        '📐 Region') print region ;;
        '🪟 Window') print window ;;
        '🖥️ Monitor') print monitor ;;
        '🌐 Desktop') print desktop ;;
        '') return 1 ;;
        *) die "unsupported choice: $choice" ;;
    esac
}

wayland_window_geometry() {
    need swaymsg
    need jq
    swaymsg -t get_tree |
        jq -r '.. | select(type == "object" and .focused? == true) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' |
        head -n 1
}

wayland_monitor_geometry() {
    need swaymsg
    need jq
    need slurp
    swaymsg -t get_outputs |
        jq -r '.[] | select(.active) | "\(.rect.x),\(.rect.y) \(.rect.width)x\(.rect.height) \(.name)"' |
        slurp
}

capture_wayland() {
    local capture=$1
    local geometry

    need grim

    case $capture in
        desktop)
            settle_screen
            grim -
            ;;
        region)
            need slurp
            geometry=$(slurp) || exit 0
            settle_screen
            grim -g "$geometry" -
            ;;
        window)
            geometry=$(wayland_window_geometry)
            [[ -n $geometry ]] || die "could not determine focused Sway window"
            settle_screen
            grim -g "$geometry" -
            ;;
        monitor)
            geometry=$(wayland_monitor_geometry) || exit 0
            settle_screen
            grim -g "$geometry" -
            ;;
        *)
            usage
            exit 2
            ;;
    esac | open_editor
}

x11_monitor_geometry() {
    need xdotool
    need xrandr

    local pointer px py
    pointer=$(xdotool getmouselocation --shell)
    eval "$pointer"
    px=$X
    py=$Y

    xrandr --query |
        awk -v px="$px" -v py="$py" '
            / connected/ && match($0, /([0-9]+)x([0-9]+)\+(-?[0-9]+)\+(-?[0-9]+)/, m) {
                x=m[3]; y=m[4]; w=m[1]; h=m[2]
                if (px >= x && px < x + w && py >= y && py < y + h) {
                    printf "%sx%s+%s+%s\n", w, h, x, y
                    found=1
                    exit
                }
            }
            END { if (!found) exit 1 }
        '
}

x11_select_window() {
    need xdotool

    xdotool selectwindow 2>/dev/null
}

capture_x11() {
    local capture=$1
    local geometry input window

    if [[ $capture == region ]]; then
        need shutter
        input=$(mktemp --suffix=.png)
        settle_screen
        shutter -s -e -o "$input" || {
            rm -f -- "$input"
            exit 0
        }
        if [[ -s $input ]]; then
            open_editor_file "$input"
            rm -f -- "$input"
        else
            rm -f -- "$input"
            exit 0
        fi
        return
    fi

    need import

    case $capture in
        desktop)
            settle_screen
            import -window root png:-
            ;;
        window)
            settle_screen
            window=$(x11_select_window) || exit 0
            [[ -n $window ]] || exit 0
            settle_screen
            import -window "$window" png:-
            ;;
        monitor)
            geometry=$(x11_monitor_geometry) || die "could not determine monitor under pointer"
            settle_screen
            import -window root -crop "$geometry" png:-
            ;;
        *)
            usage
            exit 2
            ;;
    esac | open_editor
}

if [[ $mode == menu ]]; then
    mode=$(choose_mode) || exit 0
    [[ -n $mode ]] || exit 0
fi

case $mode in
    desktop|monitor|window|region)
        if [[ -n ${WAYLAND_DISPLAY:-} ]]; then
            capture_wayland "$mode"
        elif [[ -n ${DISPLAY:-} ]]; then
            capture_x11 "$mode"
        else
            die "neither WAYLAND_DISPLAY nor DISPLAY is set"
        fi
        ;;
    *)
        usage
        exit 2
        ;;
esac
