#!/usr/bin/env zsh
#
# Simple privilege escalation
#
# Provide a consistent sudo-like way to escalate
# privileges across a variety of platforms.
#

if [[ $OS == 'Windows_NT' ]]; then
    alacritty=$(whence -p alacritty.exe 2>/dev/null)
    [[ -z $alacritty ]] && alacritty=$(whence -p alacritty)
    alacritty=$(cygpath -aw "$alacritty")

    shell=$(cygpath -aw "$(readlink -f "$SHELL")")
    if [[ $# -eq 0 ]]; then
        exec cygstart --action=runas "$alacritty"
    else
        exec cygstart --action=runas "$alacritty" --command "$shell" -lc "${(qq)argv}"
    fi
else
    exec sudo "${@:--s}"
fi
