#!/usr/bin/env bash
#
# SSH wrapper to restore the terminal after the session exits
#

# Removes an entry from a colon separated path string and prints the result.
path_remove() {
    local path="$1"
    local remove="$2"

    path=":${path}:"
    path="${path//:${remove}:}"
    path="${path%:}"
    path="${path#:}"

    echo "$path"
}

# Ensure that PATH does not contain the directory of this script so subsequent
# calls to `ssh` will use the real ssh binary.
script_dir="$(cd "$(dirname "$0")" && pwd)"
PATH="$(path_remove "$PATH" "$script_dir")"

disable_private_mode() {
    # DEC private mode reset: CSI ? Ps l
    printf '\033[?%sl' "$1"
}

cleanup_terminal() {
    local mode
    local tty_fd

    # Non-interactive callers may not have a controlling terminal.
    if ! [[ -t 0 || -t 1 || -t 2 ]]; then
        return
    fi

    { exec {tty_fd}>/dev/tty; } 2>/dev/null || return

    # Disable modes that can get left enabled on disconnect.
    # 1000/1002/1003/1005/1006/1015/1016 are mouse tracking variants.
    # 1004 is focus reporting, 2004 is bracketed paste, and 2031 is
    # terminal theme notifications used by tmux.
    {
        for mode in 1000 1002 1003 1004 1005 1006 1015 1016 2004 2031; do
            disable_private_mode "$mode"
        done

        # Ensure the cursor is visible again.
        printf '\033[?25h'
    } >&$tty_fd

    exec {tty_fd}>&-
}

ssh "$@"
ssh_status=$?

cleanup_terminal
exit "$ssh_status"
