#!/usr/bin/env zsh
#
# codex
#
# Wrapper around Codex CLI that defaults the TUI syntax theme to "dark"
# without relying on mutable ~/.codex/config.toml state.
#

self="${0:A}"
local_codex="${HOME}/projects/codex-cli/codex-rs/target/release/codex"
real_codex=''
theme='dark'

if [[ -x $local_codex ]]; then
    real_codex="$local_codex"
else
    for dir in ${(s/:/)PATH}; do
        [[ -z $dir ]] && dir='.'
        candidate="${dir}/codex"
        [[ -x $candidate ]] || continue
        [[ "${candidate:A}" == "$self" ]] && continue
        real_codex="$candidate"
        break
    done
fi

if [[ -z $real_codex ]]; then
    echo "codex wrapper: could not find upstream codex in PATH" >&2
    exit 127
fi

if [[ -n $DBUS_SESSION_BUS_ADDRESS || -n $DISPLAY || -n $WAYLAND_DISPLAY ]] && whence gsettings > /dev/null; then
    color_scheme=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null | tr -d "'")
    case $color_scheme in
        prefer-light|default)
            theme='light'
            ;;
    esac
fi

exec "$real_codex" -c "tui.theme=\"${theme}\"" "$@"
