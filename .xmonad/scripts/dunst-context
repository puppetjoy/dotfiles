#!/usr/bin/env python3

import json
import subprocess
import sys


def notification_appname(notification):
    return notification.get("appname", {}).get("data", "")


def displayed_count():
    try:
        return int(subprocess.check_output(
            ["dunstctl", "count", "displayed"],
            text=True,
        ).strip())
    except Exception:
        return 0


def latest_notification_appname():
    try:
        history = subprocess.check_output(["dunstctl", "history"], text=True)
        data = json.loads(history)
        notifications = data.get("data", [[]])[0]
    except Exception:
        return ""

    if not notifications:
        return ""

    return notification_appname(notifications[0])


def activate_telegram():
    windows = subprocess.run(
        ["xdotool", "search", "--class", "Telegram"],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
    ).stdout.splitlines()

    if windows:
        subprocess.run(["xdotool", "windowactivate", windows[0]], check=False)


def main():
    appname = latest_notification_appname() if displayed_count() else ""

    status = subprocess.run(["dunstctl", "context"], check=False).returncode
    if status != 0:
        sys.exit(status)

    if appname == "Telegram Desktop":
        activate_telegram()


if __name__ == "__main__":
    main()
