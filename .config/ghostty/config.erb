theme = light:Light,dark:Dark
<% if @facts['os']['name'] == 'Nest' && @facts['preprocessed'] != 'true' -%>
font-size = 9.5
mouse-scroll-multiplier = precision:0.2
<% else -%>
font-size = 11.5
font-thicken = true
font-thicken-strength = 128
window-padding-x = 3
<% end -%>
confirm-close-surface = false
term = xterm-ghostty-powerline

