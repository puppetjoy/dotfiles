<% require 'colorscheme'
dark = ColorScheme.dark.colors_by_base
gui_scaling_factor = @facts['scaling'] ? @facts['scaling']['gui'] : 1
text_scaling_factor = @facts['scaling'] ? @facts['scaling']['text'] : 1
taffybar_height = (18 * text_scaling_factor).round
xmonad_edge_gap = (6.5 * text_scaling_factor).round
notification_edge_offset = (xmonad_edge_gap / 2.0).round
-%>
[global]
offset = <%= notification_edge_offset %>x<%= taffybar_height + notification_edge_offset %>
scale = <%= gui_scaling_factor %>
shrink = true
corner_radius = 4
frame_width = 0
padding = 4
horizontal_padding = 8
separator_height = 1
separator_color = foreground

font = sans 9
markup = full
format = "<b>%s</b>\n%b"
word_wrap = true

enable_recursive_icon_lookup = true
icon_position = left
icon_theme = breeze-dark
min_icon_size = 24

dmenu = /usr/bin/rofi -dmenu -p dunst
sticky_history = false

[urgency_low]
background = "<%= dark[0x01].shade.web %>e6"
foreground = "<%= dark[0x04].web %>"

[urgency_normal]
background = "<%= dark[0x01].shade.web %>e6"
foreground = "<%= dark[0x06].web %>"

[urgency_critical]
background = "<%= dark[0x08].shade.web %>e6"
foreground = "<%= dark[0x06].web %>"

# vim:ft=dosini
