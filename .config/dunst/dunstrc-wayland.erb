<% require 'colorscheme'
dark = ColorScheme.dark.colors_by_base
gui_scaling_factor = @facts['scaling'] ? @facts['scaling']['gui'] : 1
text_scaling_factor = @facts['scaling'] ? @facts['scaling']['text'] : 1
sway_scaling_ratio = text_scaling_factor / gui_scaling_factor
sway_edge_gap = (13 * sway_scaling_ratio).round
notification_edge_offset = (sway_edge_gap / 2.0).round
-%>
[global]
<% if @facts['primary_output'] -%>
monitor = <%= @facts['monitor_layout'].reverse.index @facts['primary_output'] %>
<% end -%>
offset = <%= notification_edge_offset %>x<%= notification_edge_offset %>
shrink = true
corner_radius = 4
frame_width = 0
padding = 4
horizontal_padding = 8
separator_height = 1
separator_color = "<%= dark[0x02].shade.web %>"

font = sans <%= 9 * text_scaling_factor %>
markup = full
format = "<b>%s</b>\n%b"
word_wrap = true

enable_recursive_icon_lookup = true
icon_position = left
icon_theme = breeze-dark
min_icon_size = 24

dmenu = /usr/bin/rofi -dmenu -p dunst
sticky_history = false

[urgency_low]
background = "<%= dark[0x01].shade.web %>e6"
foreground = "<%= dark[0x04].web %>"

[urgency_normal]
background = "<%= dark[0x01].shade.web %>e6"
foreground = "<%= dark[0x06].web %>"

[urgency_critical]
background = "<%= dark[0x08].shade.web %>e6"
foreground = "<%= dark[0x06].web %>"

# vim:ft=dosini
